{
  "name": "@json-to-office/json-to-pptx",
  "version": "0.8.0",
  "description": "Professional .pptx presentation generation from JSON - Public API package",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepublishOnly": "node ../../scripts/copy-license.cjs"
  },
  "dependencies": {
    "@json-to-office/core-pptx": "workspace:^",
    "@json-to-office/shared": "workspace:^",
    "@json-to-office/shared-pptx": "workspace:^"
  },
  "peerDependencies": {
    "pptxgenjs": "^3.12.0"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "tsup": "8.5.0",
    "typescript": "5.3.3"
  },
  "keywords": [
    "pptx",
    "powerpoint",
    "presentation",
    "generator",
    "typescript",
    "json"
  ],
  "author": "Paolo Barbato",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Wiseair-srl/json-to-office.git",
    "directory": "packages/json-to-pptx"
  },
  "homepage": "https://github.com/Wiseair-srl/json-to-office/tree/main/packages/json-to-pptx",
  "bugs": {
    "url": "https://github.com/Wiseair-srl/json-to-office/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
