{
  "name": "@json-to-office/json-to-docx",
  "version": "0.1.0",
  "description": "Professional .docx document generation from JSON - Public API package",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepublishOnly": "cp ../../LICENSE ."
  },
  "dependencies": {
    "@json-to-office/core-docx": "workspace:^",
    "@json-to-office/shared": "workspace:^",
    "@json-to-office/shared-docx": "workspace:^"
  },
  "peerDependencies": {
    "docx": "9.5.1",
    "highcharts-export-server": "5.0.0"
  },
  "peerDependenciesMeta": {
    "highcharts-export-server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "tsup": "8.5.0",
    "typescript": "5.3.3"
  },
  "keywords": [
    "docx",
    "document",
    "generator",
    "typescript",
    "json",
    "word"
  ],
  "author": "Paolo Barbato",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Wiseair-srl/json-to-office.git",
    "directory": "packages/json-to-docx"
  },
  "homepage": "https://github.com/Wiseair-srl/json-to-office/tree/main/packages/json-to-docx",
  "bugs": {
    "url": "https://github.com/Wiseair-srl/json-to-office/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
