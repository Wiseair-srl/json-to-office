{
  "name": "@json-to-office/jto",
  "version": "0.4.1",
  "description": "JSON to Office CLI - Unified document and presentation generation",
  "type": "module",
  "bin": {
    "jto": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/cli.js": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && vite build --config src/client/vite.config.ts",
    "build:server": "tsup",
    "build:client": "vite build --config src/client/vite.config.ts",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "cp ../../LICENSE ."
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.143",
    "@hono/node-server": "1.13.7",
    "@json-to-office/core-docx": "workspace:^",
    "@json-to-office/core-pptx": "workspace:^",
    "@json-to-office/shared": "workspace:^",
    "@json-to-office/shared-docx": "workspace:^",
    "@json-to-office/shared-pptx": "workspace:^",
    "@monaco-editor/react": "4.7.0",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sinclair/typebox": "0.34.38",
    "@tailwindcss/postcss": "4.1.11",
    "@tanstack/react-query": "5.62.11",
    "ai": "^6.0.141",
    "ai-sdk-provider-claude-code": "^3.4.4",
    "ajv": "8.12.0",
    "ajv-formats": "2.1.1",
    "axios": "1.7.9",
    "boxen": "^8.0.1",
    "chalk": "5.3.0",
    "class-variance-authority": "0.7.1",
    "cli-table3": "^0.6.5",
    "clsx": "2.1.1",
    "commander": "11.1.0",
    "constrained-editor-plugin": "1.4.0",
    "cosmiconfig": "9.0.0",
    "docx-preview": "0.3.3",
    "dotenv": "16.3.1",
    "glob": "^13.0.0",
    "hono": "4.6.14",
    "idb-keyval": "^6.2.2",
    "jsonrepair": "^3.13.3",
    "lodash.debounce": "4.0.8",
    "lru-cache": "10.4.3",
    "lucide-react": "0.468.0",
    "mime-types": "2.1.35",
    "monaco-editor": "0.52.2",
    "ora": "8.0.1",
    "postcss": "8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.54.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "2.1.7",
    "react-router": "7.0.2",
    "react-router-dom": "7.0.2",
    "recharts": "2.15.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "3.0.1",
    "tailwindcss": "4.1.11",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.20.3",
    "unpdf": "^1.4.0",
    "vite": "6.0.5",
    "zod": "^4.0.0",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@types/lodash.debounce": "4.0.9",
    "@types/mime-types": "2.1.4",
    "@types/node": "20.11.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.3.4",
    "prompts": "2.4.2",
    "tsup": "8.5.0",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Paolo Barbato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wiseair-srl/json-to-office.git",
    "directory": "packages/jto"
  },
  "homepage": "https://github.com/Wiseair-srl/json-to-office/tree/main/packages/jto",
  "bugs": {
    "url": "https://github.com/Wiseair-srl/json-to-office/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "json-to-office",
    "typescript",
    "cli",
    "docx",
    "pptx",
    "document",
    "presentation"
  ]
}
