        { "name": "shape", "props": { "type": "roundRect", "fill": { "color": "7e3af2" }, "rectRadius": 0.1, "text": "Users\n12,847", "fontSize": 14, "fontColor": "FFFFFF", "bold": true, "align": "center", "valign": "middle", "grid": { "column": 3, "row": 1, "columnSpan": 3 } } },
        { "name": "shape", "props": { "type": "roundRect", "fill": { "color": "0e9f6e" }, "rectRadius": 0.1, "text": "Uptime\n99.97%", "fontSize": 14, "fontColor": "FFFFFF", "bold": true, "align": "center", "valign": "middle", "grid": { "column": 6, "row": 1, "columnSpan": 3 } } },
        { "name": "shape", "props": { "type": "roundRect", "fill": { "color": "E02424" }, "rectRadius": 0.1, "text": "Incidents\n3 Open", "fontSize": 14, "fontColor": "FFFFFF", "bold": true, "align": "center", "valign": "middle", "grid": { "column": 9, "row": 1, "columnSpan": 3 } } },
