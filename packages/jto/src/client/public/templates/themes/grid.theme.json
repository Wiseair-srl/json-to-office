{
  "name": "grid",
  "colors": {
    "primary": "#1a56db",
    "secondary": "#7e3af2",
    "accent": "#0e9f6e",
    "background": "#f9fafb",
    "text": "#1f2937"
  },
  "fonts": {
    "heading": "Arial",
    "body": "Arial"
  },
  "defaults": {
    "fontSize": 16,
    "fontColor": "#1f2937"
  },
  "grid": {
    "columns": 12,
    "rows": 6,
    "margin": { "top": 0.75, "right": 0.5, "bottom": 0.5, "left": 0.5 },
    "gutter": { "column": 0.2, "row": 0.2 }
  }
}
