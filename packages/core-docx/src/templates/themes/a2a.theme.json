{
  "$schema": "../../../../shared/json-schemas/theme.schema.json",
  "name": "a2a",
  "displayName": "A2A Corporate",
  "description": "Official A2A corporate theme with Life Sans typography",
  "version": "2.0.0",
  "colors": {
    "primary": "#009fda",
    "secondary": "#575756",
    "accent": "#016abd",
    "text": "#000000",
    "background": "#FFFFFF",
    "border": "#000000",
    "textPrimary": "#575756",
    "textSecondary": "#009fda",
    "textMuted": "#6E777E",
    "borderPrimary": "#000000",
    "borderSecondary": "#575756",
    "backgroundPrimary": "#FFFFFF",
    "backgroundSecondary": "#EEF3F7"
  },
  "fonts": {
    "heading": {
      "family": "Life Sans",
      "size": 57
    },
    "body": {
      "family": "Life Sans",
      "size": 9
    },
    "mono": {
      "family": "Life Sans",
      "size": 9
    },
    "light": {
      "family": "Life Sans",
      "size": 57
    }
  },
  "page": {
    "size": "A4",
    "margins": {
      "top": 567,
      "bottom": 567,
      "left": 723,
      "right": 723,
      "header": 720,
      "footer": 720,
      "gutter": 0
    }
  },
  "styles": {
    "normal": {
      "font": "body",
      "size": 9,
      "color": "textPrimary",
      "alignment": "left",
      "lineSpacing": {
        "type": "atLeast",
        "value": 11
      },
      "spacing": {
        "after": 6
      }
    },
    "title": {
      "font": "heading",
      "size": 57,
      "color": "primary",
      "characterSpacing": {
        "type": "condensed",
        "value": 2.5
      },
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 12
      },
      "priority": 11,
      "baseStyle": "heading1"
    },
    "subtitle": {
      "font": "heading",
      "size": 22,
      "bold": true,
      "color": "primary",
      "characterSpacing": {
        "type": "condensed",
        "value": 1
      },
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 12
      },
      "followingStyle": "normal",
      "priority": 12,
      "baseStyle": "normal"
    },
    "heading1": {
      "font": "heading",
      "size": 57,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "characterSpacing": {
        "type": "condensed",
        "value": 2.5
      },
      "spacing": {
        "after": 42
      },
      "priority": 10,
      "widowControl": true,
      "keepNext": true,
      "keepLinesTogether": true,
      "outlineLevel": 1
    },
    "heading2": {
      "font": "heading",
      "size": 22,
      "bold": true,
      "color": "secondary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "characterSpacing": {
        "type": "condensed",
        "value": 1
      },
      "spacing": {
        "after": 12
      },
      "priority": 10,
      "baseStyle": "subtitle",
      "outlineLevel": 2
    },
    "heading3": {
      "font": "heading",
      "size": 12,
      "bold": true,
      "color": "secondary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 16
      },
      "priority": 10,
      "borders": {
        "top": {
          "style": "single",
          "size": 1,
          "color": "borderPrimary",
          "space": 4
        }
      },
      "followingStyle": "heading4",
      "outlineLevel": 3
    },
    "heading4": {
      "font": "heading",
      "size": 13,
      "bold": true,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "before": 16,
        "after": 4
      },
      "priority": 10,
      "outlineLevel": 4
    },
    "heading5": {
      "font": "heading",
      "size": 11,
      "bold": true,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 6
      },
      "priority": 10,
      "outlineLevel": 5
    },
    "heading6": {
      "font": "heading",
      "size": 10,
      "bold": true,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 6
      },
      "priority": 10,
      "outlineLevel": 6
    }
  }
}
