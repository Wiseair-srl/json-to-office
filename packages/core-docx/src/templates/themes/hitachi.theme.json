{
  "$schema": "../../../../shared/json-schemas/theme.schema.json",
  "name": "hitachi",
  "displayName": "Hitachi Corporate",
  "description": "Official Hitachi corporate theme with Montserrat typography and brand colors",
  "version": "2.0.0",
  "colors": {
    "primary": "#FA010E",
    "secondary": "#222222",
    "accent": "#CC0100",
    "text": "#222222",
    "background": "#FFFFFF",
    "border": "#000000",
    "textPrimary": "#222222",
    "textSecondary": "#CC0100",
    "textMuted": "#737373",
    "borderPrimary": "#000000",
    "borderSecondary": "#222222",
    "backgroundPrimary": "#FFFFFF",
    "backgroundSecondary": "#F4F4F4"
  },
  "fonts": {
    "heading": {
      "family": "Montserrat",
      "size": 22
    },
    "body": {
      "family": "Montserrat",
      "size": 11
    },
    "mono": {
      "family": "Montserrat",
      "size": 11
    },
    "light": {
      "family": "Montserrat",
      "size": 57
    }
  },
  "page": {
    "size": "A4",
    "margins": {
      "top": 700,
      "bottom": 700,
      "left": 500,
      "right": 500,
      "header": 500,
      "footer": 200,
      "gutter": 0
    }
  },
  "styles": {
    "normal": {
      "font": "body",
      "size": 11,
      "color": "textPrimary",
      "alignment": "justify",
      "lineSpacing": {
        "type": "atLeast",
        "value": 11
      },
      "characterSpacing": {
        "type": "condensed",
        "value": 1.5
      },
      "spacing": {
        "after": 6
      }
    },
    "title": {
      "font": "light",
      "size": 57,
      "bold": false,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "characterSpacing": {
        "type": "condensed",
        "value": 2.5
      },
      "spacing": {
        "after": 6
      },
      "priority": 11,
      "baseStyle": "heading1"
    },
    "subtitle": {
      "font": "heading",
      "size": 22,
      "bold": false,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 12
      },
      "followingStyle": "normal",
      "priority": 12,
      "baseStyle": "normal"
    },
    "heading1": {
      "font": "heading",
      "size": 22,
      "bold": false,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 12
      },
      "priority": 10,
      "widowControl": true,
      "keepNext": true,
      "keepLinesTogether": true,
      "outlineLevel": 1
    },
    "heading2": {
      "font": "heading",
      "size": 14,
      "bold": false,
      "color": "secondary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 12
      },
      "priority": 10,
      "baseStyle": "subtitle",
      "outlineLevel": 2
    },
    "heading3": {
      "font": "heading",
      "size": 12,
      "bold": false,
      "color": "secondary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 16
      },
      "priority": 10,
      "borders": {
        "top": {
          "style": "single",
          "size": 1,
          "color": "borderPrimary",
          "space": 4
        }
      },
      "followingStyle": "heading4",
      "outlineLevel": 3
    },
    "heading4": {
      "font": "heading",
      "size": 13,
      "bold": false,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "before": 16,
        "after": 4
      },
      "priority": 10,
      "outlineLevel": 4
    },
    "heading5": {
      "font": "heading",
      "size": 11,
      "bold": false,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 6
      },
      "priority": 10,
      "outlineLevel": 5
    },
    "heading6": {
      "font": "heading",
      "size": 10,
      "bold": false,
      "color": "primary",
      "alignment": "left",
      "lineSpacing": {
        "type": "single"
      },
      "spacing": {
        "after": 6
      },
      "priority": 10,
      "outlineLevel": 6
    }
  },
  "componentDefaults": {
    "text-space-after": {
      "spacing": {
        "after": 24
      }
    }
  }
}
