{
  "$schema": "../../../shared/json-schemas/document.schema.json",
  "name": "docx",
  "props": {
    "title": "Image Default Width Example",
    "metadata": {
      "author": "JTD Library"
    }
  },
  "children": [
    {
      "name": "heading",
      "props": {
        "content": "Image Default Width (100%)",
        "level": 1
      }
    },
    {
      "name": "paragraph",
      "props": {
        "content": "When no width is specified, images now default to **100%** of the available document width (page width minus margins)."
      }
    },
    {
      "name": "heading",
      "props": {
        "content": "Image Without Width Property",
        "level": 2
      }
    },
    {
      "name": "image",
      "props": {
        "path": "https://picsum.photos/800/400",
        "caption": "This image has no width specified - defaults to 100% of available width",
        "alignment": "center"
      }
    },
    {
      "name": "heading",
      "props": {
        "content": "Explicit 100% Width",
        "level": 2
      }
    },
    {
      "name": "image",
      "props": {
        "path": "https://picsum.photos/800/400",
        "width": "100%",
        "caption": "This image explicitly sets width to 100% - same result as default",
        "alignment": "center"
      }
    },
    {
      "name": "heading",
      "props": {
        "content": "Comparison: 50% Width",
        "level": 2
      }
    },
    {
      "name": "image",
      "props": {
        "path": "https://picsum.photos/800/400",
        "width": "50%",
        "caption": "This image is set to 50% width for comparison",
        "alignment": "center"
      }
    }
  ]
}
