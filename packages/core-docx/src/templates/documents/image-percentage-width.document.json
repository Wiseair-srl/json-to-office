{
  "$schema": "../../../shared/json-schemas/document.schema.json",
  "name": "report",
  "props": {
    "title": "Image Percentage Width Example",
    "metadata": {
      "author": "JTD Library"
    }
  },
  "children": [
    {
      "name": "heading",
      "props": {
        "content": "Image Width: Percentage vs Pixels",
        "level": 1
      }
    },
    {
      "name": "paragraph",
      "props": {
        "content": "This example demonstrates how to use percentage-based widths for images. The percentage is calculated relative to the available document width (page width minus margins)."
      }
    },
    {
      "name": "heading",
      "props": {
        "content": "100% Width (Full Available Width)",
        "level": 2
      }
    },
    {
      "name": "image",
      "props": {
        "path": "https://picsum.photos/800/400",
        "width": "100%",
        "caption": "Image at 100% width - spans full available document width",
        "alignment": "center"
      }
    },
    {
      "name": "heading",
      "props": {
        "content": "75% Width",
        "level": 2
      }
    },
    {
      "name": "image",
      "props": {
        "path": "https://picsum.photos/800/400",
        "width": "75%",
        "caption": "Image at 75% width - three quarters of available width",
        "alignment": "center"
      }
    },
    {
      "name": "heading",
      "props": {
        "content": "50% Width",
        "level": 2
      }
    },
    {
      "name": "image",
      "props": {
        "path": "https://picsum.photos/800/400",
        "width": "50%",
        "caption": "Image at 50% width - half of available width",
        "alignment": "center"
      }
    },
    {
      "name": "heading",
      "props": {
        "content": "Fixed Pixel Width (400px)",
        "level": 2
      }
    },
    {
      "name": "image",
      "props": {
        "path": "https://picsum.photos/800/400",
        "width": 400,
        "caption": "Image at 400px width - traditional fixed pixel width for comparison",
        "alignment": "center"
      }
    },
    {
      "name": "paragraph",
      "props": {
        "content": "**Note**: Percentage widths are particularly useful for responsive documents where the width should adapt to different page sizes or margin settings."
      }
    }
  ]
}
