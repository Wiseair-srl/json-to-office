{
  "name": "@json-to-office/core-pptx",
  "version": "0.8.0",
  "description": "Core PPTX presentation generation engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration",
    "build:js": "tsup",
    "build:types": "tsc --emitDeclarationOnly --declaration",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "prepublishOnly": "node -e \"require('fs').copyFileSync('../../LICENSE','LICENSE')\""
  },
  "dependencies": {
    "@json-to-office/shared": "workspace:^",
    "@json-to-office/shared-pptx": "workspace:^",
    "@sinclair/typebox": "0.34.38",
    "jszip": "3.10.1",
    "probe-image-size": "7.2.3",
    "pptxgenjs": "^3.12.0"
  },
  "devDependencies": {
    "@types/node": "20.11.0",
    "@types/probe-image-size": "7.2.4",
    "tsup": "8.5.0",
    "typescript": "5.3.3"
  },
  "license": "MIT",
  "author": "Paolo Barbato",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wiseair-srl/json-to-office.git",
    "directory": "packages/core-pptx"
  },
  "homepage": "https://github.com/Wiseair-srl/json-to-office/tree/main/packages/core-pptx",
  "bugs": {
    "url": "https://github.com/Wiseair-srl/json-to-office/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "keywords": [
    "json-to-office",
    "typescript",
    "pptx",
    "presentation",
    "powerpoint"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
