        }
      },
      "children": [
        {
          "name": "text",
          "props": {
            "text": "Every SaaS company generates documents — invoices, reports, proposals, contracts. Yet document infrastructure remains one of the last unsolved platform problems.",
            "fontSize": 16,
            "color": "text",
            "lineSpacing": 24,
            "grid": { "column": 0, "row": 2, "columnSpan": 12, "rowSpan": 2 }
          }
        },
        {
          "name": "shape",
          "props": {
            "type": "roundRect",
            "fill": { "color": "background2" },
            "rectRadius": 0.1,
            "text": "80%\nstill use file-based\ntemplates",
            "fontSize": 15,
            "bold": true,
            "fontColor": "primary",
            "align": "center",
            "valign": "middle",
            "grid": { "column": 0, "row": 4, "columnSpan": 4, "rowSpan": 3 }
          }
        },
        {
          "name": "shape",
          "props": {
            "type": "roundRect",
            "fill": { "color": "background2" },
            "rectRadius": 0.1,
            "text": "3 weeks\navg integration\ntime",
            "fontSize": 15,
            "bold": true,
            "fontColor": "accent4",
            "align": "center",
            "valign": "middle",
            "grid": { "column": 4, "row": 4, "columnSpan": 4, "rowSpan": 3 }
          }
        },
        {
          "name": "shape",
          "props": {
            "type": "roundRect",
            "fill": { "color": "background2" },
            "rectRadius": 0.1,
            "text": "$50K+\nannual doc infra\ncost per company",
            "fontSize": 15,
            "bold": true,
            "fontColor": "accent5",
            "align": "center",
            "valign": "middle",
            "grid": { "column": 8, "row": 4, "columnSpan": 4, "rowSpan": 3 }
          }
        },
        {
          "name": "text",
          "props": {
            "text": "Template-based systems break when document structure is dynamic. Code-first libraries trap definitions inside application code, making them invisible to designers and non-technical stakeholders.",
            "fontSize": 13,
            "color": "text2",
            "lineSpacing": 22,
            "grid": { "column": 0, "row": 8, "columnSpan": 12, "rowSpan": 3 }
          }
        }
      ]
    },
    {
      "name": "slide",
      "props": {
        "template": "CONTENT_TEMPLATE",
        "placeholders": {
          "heading": { "name": "text", "props": { "text": "The Solution" } }
        }
      },
      "children": [
        {
          "name": "text",
          "props": {
            "text": "Meridian treats documents as serializable JSON — a portable, version-controlled, AI-friendly format that decouples structure from rendering.",
            "fontSize": 16,
            "color": "text",
            "lineSpacing": 24,
            "grid": { "column": 0, "row": 2, "columnSpan": 12, "rowSpan": 2 }
          }
        },

        {
          "name": "shape",
          "props": {
            "type": "roundRect",
            "fill": { "color": "background2" },
            "rectRadius": 0.08,
            "grid": { "column": 0, "row": 4, "columnSpan": 4, "rowSpan": 3 }
          }
        },
        {
          "name": "text",
          "props": {
            "text": "JSON-First",
            "fontSize": 14,
            "bold": true,
            "color": "accent",
            "grid": { "column": 0, "row": 4, "columnSpan": 4, "rowSpan": 1 }
          }
        },
        {
          "name": "text",
          "props": {
            "text": "Define documents as data. Store in databases, transmit via APIs, generate with AI.",
            "fontSize": 12,
            "color": "text2",
            "lineSpacing": 20,
            "grid": { "column": 0, "row": 5, "columnSpan": 4, "rowSpan": 2 }
          }
        },

        {
          "name": "shape",
          "props": {
            "type": "roundRect",
            "fill": { "color": "background2" },
            "rectRadius": 0.08,
            "grid": { "column": 4, "row": 4, "columnSpan": 4, "rowSpan": 3 }
          }
        },
        {
          "name": "text",
          "props": {
            "text": "Multi-Format",
            "fontSize": 14,
            "bold": true,
            "color": "accent",
            "grid": { "column": 4, "row": 4, "columnSpan": 4, "rowSpan": 1 }
          }
        },
        {
          "name": "text",
          "props": {
            "text": "One schema, multiple outputs — DOCX, PPTX, PDF. Consistent design across every format.",
            "fontSize": 12,
            "color": "text2",
            "lineSpacing": 20,
            "grid": { "column": 4, "row": 5, "columnSpan": 4, "rowSpan": 2 }
          }
        },

        {
          "name": "shape",
          "props": {
            "type": "roundRect",
            "fill": { "color": "background2" },
            "rectRadius": 0.08,
            "grid": { "column": 8, "row": 4, "columnSpan": 4, "rowSpan": 3 }
