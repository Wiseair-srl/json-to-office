        },
        {
          "name": "text",
          "props": {
            "text": "Theme System",
            "fontSize": 14,
            "bold": true,
            "color": "accent",
            "grid": { "column": 8, "row": 4, "columnSpan": 4, "rowSpan": 1 }
          }
        },
        {
          "name": "text",
          "props": {
            "text": "Design tokens, component defaults, and brand assets. Change the theme, change every document.",
            "fontSize": 12,
            "color": "text2",
            "lineSpacing": 20,
            "grid": { "column": 8, "row": 5, "columnSpan": 4, "rowSpan": 2 }
          }
        },

