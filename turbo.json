{
  "$schema": "https://v2-8-16.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"],
      "inputs": [
        "src/**",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts",
        "package.json",
        "tsconfig.json",
        "tsup.config.ts"
      ],
      "env": ["NODE_ENV"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:open": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "cache": false
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "//#generate:schemas": {
      "dependsOn": [
        "@json-to-office/shared#build",
        "@json-to-office/shared-docx#build",
        "@json-to-office/shared-pptx#build"
      ],
      "outputs": ["schemas/**"],
      "inputs": [
        "scripts/generate-schemas.ts",
        "packages/shared/dist/**",
        "packages/shared-docx/dist/**",
        "packages/shared-pptx/dist/**"
      ]
    }
  }
}
